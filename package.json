{
  "name": "virtual-grid",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201",
    "build": "ng build",
    "build:lib": "ng b sat-virtual-grid --watch",
    "watch": "ng b --watch --configuration development",
    "test": "ng test",
    "version": "cd ./projects/sat-virtual-grid && npm version patch && cd ../../",
    "publish": "npm run version && ng build sat-virtual-grid && cd dist/sat-virtual-grid && npm pack && npm publish"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^15.2.9",
    "@angular/common": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "lorem-ipsum": "^2.0.8",
    "ngx-scrollbar": "^10.0.1",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular/cli": "~18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@angular/elements": "^18.2.14",
    "@schematics/angular": "^15.0.3",
    "@types/jasmine": "~4.0.0",
    "jasmine-core": "~4.1.0",
    "karma": "~6.3.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "ng-packagr": "^16.2.3",
    "typescript": "~5.4.5",
    "webpack": "^5.101.3",
    "eslint": "^8.28.0",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-prefer-arrow": "latest"
  }
}