{
  "name": "virtual-grid",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201",
    "build": "ng build",
    "build:lib": "ng b sat-virtual-grid --watch",
    "watch": "ng b --watch --configuration development",
    "test": "ng test",
    "version": "cd ./projects/sat-virtual-grid && npm version patch && cd ../../",
    "publish": "npm run version && ng build sat-virtual-grid && cd dist/sat-virtual-grid && npm pack && npm publish"
  },
  "private": true,
  "dependencies": {
